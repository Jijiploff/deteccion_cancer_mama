# Copia este archivo como ".env" para desarrollo local (no lo subas al repo)

# Ruta al modelo .keras dentro del contenedor/proyecto
MODEL_PATH=models/modelo_cancer_mama.keras

# Dominio(s) de tu frontend en Vercel, separados por coma si tienes varios
# (producción + preview deployments)
FRONTEND_URL=http://localhost:3000

# development | production
ENVIRONMENT=development

LOG_LEVEL=INFO

# Preprocesamiento
APPLY_CLAHE=true
PREDICTION_THRESHOLD=0.5

# Seguridad
MAX_FILE_SIZE_MB=5

# Rate limiting
RATE_LIMIT_PREDICT=10/minute
RATE_LIMIT_DEFAULT=60/minute

# Historial en memoria
HISTORY_MAX_ITEMS=50

# --- Google Drive File IDs para descarga automática de modelos ---
# Obtén el FILE_ID del enlace compartido de Google Drive para cada modelo.
# Formato del enlace: https://drive.google.com/file/d/<FILE_ID>/view
# Si se dejan vacíos, se usan los archivos locales en backend/models/
# CNN_MODEL_FILE_ID=
# ENSEMBLE_MODEL_FILE_ID=
# TABULAR_MODEL_FILE_ID=